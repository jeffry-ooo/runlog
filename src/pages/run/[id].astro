---
import Base from '../../layouts/Base.astro';
import activities from '../../../data/activities.json';

export const prerender = true;

export function getStaticPaths() {
  return activities.map((a) => ({
    params: { id: a.id },
    props: { activity: a },
  }));
}

const { activity: a } = Astro.props;

const fmtDist = (m) => (m / 1000).toFixed(1) + 'KM';
const fmtPace = (secPerKm) => {
  const m = Math.floor(secPerKm / 60);
  const s = Math.round(secPerKm % 60).toString().padStart(2, '0');
  return `${m}:${s}/KM`;
};
const fmtDate = (iso, tz) =>
  new Date(iso)
    .toLocaleDateString('en-GB', { day: 'numeric', month: 'long', timeZone: tz })
    .toUpperCase();
const fmtTime = (iso, tz) =>
  new Date(iso).toLocaleTimeString('en-GB', {
    hour: '2-digit', minute: '2-digit', timeZone: tz, hour12: false,
  });

function computeSplits(distSeries, speedSeries, hrSeries) {
  const splits = [];
  let splitNum = 1;
  let hrAcc = [], paceAcc = [];
  if (!distSeries || !speedSeries || !hrSeries) return splits;
  for (let i = 1; i < distSeries.length; i++) {
    if (hrSeries[i]) hrAcc.push(hrSeries[i]);
    if (speedSeries[i] > 0) paceAcc.push(1 / speedSeries[i]);
    if (distSeries[i] >= splitNum * 1000) {
      const avgHR = hrAcc.length ? Math.round(hrAcc.reduce((s, v) => s + v, 0) / hrAcc.length) : null;
      const avgPace = paceAcc.length ? Math.round((paceAcc.reduce((s, v) => s + v, 0) / paceAcc.length) * 1000) : null;
      splits.push({ km: splitNum, hr: avgHR, pace: avgPace });
      splitNum++; hrAcc = []; paceAcc = [];
    }
  }
  return splits;
}

const splits = computeSplits(a.distance_series, a.speed_series, a.hr_series);
const ZONE_COLORS = ['#a8c5a0', '#6faadc', '#f0c060', '#e88040', '#d04040'];
const ZONE_NAMES  = ['Z1', 'Z2', 'Z3', 'Z4', 'Z5'];
const totalZ  = a.hr_zones ? a.hr_zones.reduce((s, v) => s + v, 0) : 0;
const beers   = Math.round(a.calories / 200);
const hasTrack = !!(a.track_lat && a.track_lat.length > 2);
const hasHR    = !!(a.hr_series && a.hr_series.length > 0);
const base     = import.meta.env.BASE_URL;
---

<Base title={fmtDate(a.date, a.timezone)}>
  <div class="wrap">
    <div style="padding-top: var(--pad)">
      <div class="section">
        <div class="row-3">
          <span>{fmtDate(a.date, a.timezone)}</span>
          <span>{fmtTime(a.date, a.timezone)}</span>
          <span>{a.temperature}°</span>
        </div>
        <div class="row-2"><span>DISTANCE</span><span>{fmtDist(a.distance_m)}</span></div>
        <div class="row-2"><span>EFFORT</span><span>{a.effort}</span></div>
        <div class="row-2"><span>AVG. HR</span><span>{a.heartrate_avg}BPM</span></div>
        <div class="row-2"><span>MAX. HR</span><span>{a.heartrate_max}BPM</span></div>
        <div class="row-2"><span>ELEVATION</span><span>↑{a.elevation_ascent}M</span></div>
        <div class="row-2"><span>CALORIES</span><span>{a.calories}KCAL</span></div>
      </div>

      {hasHR && (
        <div class="section">
          <div class="chart-label">HEART RATE</div>
          <canvas
            id="hr-canvas"
            width="600"
            height="64"
            style="display:block;width:100%;height:64px;"
            data-hr={JSON.stringify(a.hr_series)}
            data-hr-avg={String(a.heartrate_avg || 0)}
          ></canvas>
        </div>
      )}

      {a.hr_zones && totalZ > 0 && (
        <div class="section">
          <div class="chart-label">HR ZONES</div>
          <div class="zones-bar">
            {a.hr_zones.map((v, i) => {
              const pct = totalZ > 0 ? (v / totalZ) * 100 : 0;
              return pct > 0 ? (
                <div class="zone-seg" style={`width:${pct.toFixed(1)}%;background:${ZONE_COLORS[i]}`}></div>
              ) : null;
            })}
          </div>
          <div class="zones-legend">
            {a.hr_zones.map((v, i) => v > 0 ? (
              <div class="zone-item">
                <div class="zone-dot" style={`background:${ZONE_COLORS[i]}`}></div>
                <span>{ZONE_NAMES[i]} {Math.round(v / 60)}min</span>
              </div>
            ) : null)}
          </div>
        </div>
      )}

      {splits.length > 0 && (
        <div class="section">
          <div class="chart-label">SPLITS</div>
          <div class="splits-grid">
            {splits.map((s) => (
              <Fragment>
                <span>KM {s.km}</span>
                <span>
                  {s.pace ? fmtPace(s.pace) : '—'}
                  {s.hr ? `  ${s.hr}BPM` : ''}
                </span>
              </Fragment>
            ))}
          </div>
        </div>
      )}

      <div class="beer-row">
        <span>BEERS EARNED</span>
        <span>{beers}</span>
      </div>

      {hasTrack && (
        <div>
          <hr class="rule" />
          <div style="padding: var(--gap) 0 0;">
            <canvas
              id="track-canvas"
              width="600"
              height="200"
              style="display:block;width:100%;height:200px;"
              data-lat={JSON.stringify(a.track_lat)}
              data-lng={JSON.stringify(a.track_lng)}
            ></canvas>
          </div>
          <div style="padding-bottom: var(--gap);">
            <a href={`${base}gpx/${a.id}.gpx`} style="text-decoration:underline;">DOWNLOAD GPX</a>
          </div>
        </div>
      )}
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {

      // ── GPS track canvas ──────────────────────────────────────
      var trackEl = document.getElementById('track-canvas');
      if (trackEl) {
        var lats, lngs;
        try {
          lats = JSON.parse(trackEl.dataset.lat);
          lngs = JSON.parse(trackEl.dataset.lng);
        } catch (e) { lats = null; }

        if (lats && lats.length > 2) {
          var dpr = window.devicePixelRatio || 1;
          var w = trackEl.parentElement.offsetWidth || 600;
          var h = 200;
          trackEl.width = w * dpr;
          trackEl.height = h * dpr;
          trackEl.style.width = w + 'px';
          trackEl.style.height = h + 'px';
          var ctx = trackEl.getContext('2d');
          ctx.scale(dpr, dpr);

          var pad = 24;
          var minLat = Math.min.apply(null, lats), maxLat = Math.max.apply(null, lats);
          var minLng = Math.min.apply(null, lngs), maxLng = Math.max.apply(null, lngs);
          var rW = maxLng - minLng || 0.001, rH = maxLat - minLat || 0.001;
          var sc = Math.min((w - pad * 2) / rW, (h - pad * 2) / rH);
          var offX = (w - rW * sc) / 2, offY = (h - rH * sc) / 2;
          var toX = function (lng) { return offX + (lng - minLng) * sc; };
          var toY = function (lat) { return h - offY - (lat - minLat) * sc; };

          ctx.beginPath();
          ctx.moveTo(toX(lngs[0]), toY(lats[0]));
          for (var i = 1; i < lats.length; i++) ctx.lineTo(toX(lngs[i]), toY(lats[i]));
          ctx.strokeStyle = '#1a1814';
          ctx.lineWidth = 1.5;
          ctx.lineJoin = 'round';
          ctx.lineCap = 'round';
          ctx.stroke();

          ctx.beginPath();
          ctx.arc(toX(lngs[0]), toY(lats[0]), 3, 0, Math.PI * 2);
          ctx.fillStyle = '#1a1814';
          ctx.fill();
        }
      }

      // ── HR chart canvas ───────────────────────────────────────
      var hrEl = document.getElementById('hr-canvas');
      if (hrEl) {
        var hrSeries, hrAvg;
        try { hrSeries = JSON.parse(hrEl.dataset.hr); } catch (e) { hrSeries = null; }
        hrAvg = parseFloat(hrEl.dataset.hrAvg) || 0;

        if (hrSeries && hrSeries.length > 0) {
          var dpr2 = window.devicePixelRatio || 1;
          var hw = hrEl.parentElement.offsetWidth || 600;
          var hh = 64;
          hrEl.width = hw * dpr2;
          hrEl.height = hh * dpr2;
          hrEl.style.width = hw + 'px';
          hrEl.style.height = hh + 'px';
          var hctx = hrEl.getContext('2d');
          hctx.scale(dpr2, dpr2);

          var mn = Math.min.apply(null, hrSeries) - 8;
          var mx = Math.max.apply(null, hrSeries) + 8;
          var hpx = function (i) { return (i / (hrSeries.length - 1)) * hw; };
          var hpy = function (v) { return hh - ((v - mn) / (mx - mn)) * hh; };

          var grad = hctx.createLinearGradient(0, 0, 0, hh);
          grad.addColorStop(0, 'rgba(26,24,20,0.10)');
          grad.addColorStop(1, 'rgba(26,24,20,0.00)');
          hctx.beginPath();
          hctx.moveTo(hpx(0), hpy(hrSeries[0]));
          for (var j = 1; j < hrSeries.length; j++) hctx.lineTo(hpx(j), hpy(hrSeries[j]));
          hctx.lineTo(hpx(hrSeries.length - 1), hh);
          hctx.lineTo(0, hh);
          hctx.closePath();
          hctx.fillStyle = grad;
          hctx.fill();

          hctx.beginPath();
          hctx.moveTo(hpx(0), hpy(hrSeries[0]));
          for (var k = 1; k < hrSeries.length; k++) hctx.lineTo(hpx(k), hpy(hrSeries[k]));
          hctx.strokeStyle = 'rgba(26,24,20,0.75)';
          hctx.lineWidth = 1.5;
          hctx.lineJoin = 'round';
          hctx.stroke();

          hctx.setLineDash([3, 5]);
          hctx.beginPath();
          hctx.moveTo(0, hpy(hrAvg));
          hctx.lineTo(hw, hpy(hrAvg));
          hctx.strokeStyle = 'rgba(26,24,20,0.2)';
          hctx.lineWidth = 1;
          hctx.stroke();
          hctx.setLineDash([]);
        }
      }
    });
  </script>
</Base>
