---
import Base from '../layouts/Base.astro';
---

<Base title="ABOUT">
  <div class="wrap">
    <div style="padding-top: var(--pad)">

      <div class="section">
        <div class="row-2"><span>WHO</span><span>Jeffry. Antwerp. Trail runner.</span></div>
        <div class="row-2"><span>WHAT</span><span>A one-way running logbook. No leaderboards, no kudos.</span></div>
      </div>

      <div class="section">
        <div class="row-2"><span>WATCH</span><span>Suunto Race S</span></div>
        <div class="row-2"><span>SCRIPT</span><span>Python → Tredict API</span></div>
        <div class="row-2"><span>CLAUDE</span><span>formats and builds this log</span></div>
      </div>

      <div class="section">
        <div class="row-2"><span>GOAL</span><span>50K</span></div>
        <div class="row-2"><span>PACE</span><span>sub-6:00/KM</span></div>
        <div class="row-2"><span>PLAN</span><span><a href="https://docs.google.com/spreadsheets/d/1eWM9DmBr764_EZPUxJGY8xKKBcABpauBJvMWy43097I/edit?usp=sharing" style="text-decoration:underline;">GOOGLE SHEET</a></span></div>
      </div>

      <div class="section">
        <div class="row-2"><span>WATCH</span><span>Suunto Race S</span></div>
        <div class="row-2"><span>DATA</span><span>Tredict</span></div>
        <div class="row-2"><span>COACH</span><span>Claude</span></div>
        <div class="row-2"><span>SITE</span><span>Astro, GitHub Pages</span></div>
      </div>

    </div>
  </div>
</Base>
