---
import Base from '../layouts/Base.astro';
---

<Base title="ABOUT">
  <div class="wrap">
    <header class="site-header">
      <span><a href={import.meta.env.BASE_URL} style="text-decoration:none">RUNNING LOG</a></span>
      <span></span>
      <nav class="site-nav"><a href={`${import.meta.env.BASE_URL}about`}>ABOUT</a></nav>
    </header>

    <div style="padding: var(--pad) 0; border-bottom: 1px solid var(--rule);">
      <div class="row-2" style="margin-bottom: 16px;">
        <span>WHO</span>
        <span>Jeffry. Antwerp-based. Trail runner.</span>
      </div>
      <div class="row-2" style="margin-bottom: 16px;">
        <span>WHAT</span>
        <span>A one-way logbook. No leaderboards, no kudos, no noise.</span>
      </div>
      <div class="row-2" style="margin-bottom: 16px;">
        <span>GOAL</span>
        <span>50K — 01.11.2026</span>
      </div>
      <div class="row-2">
        <span>DATA</span>
        <span>Suunto Race → Tredict → here.</span>
      </div>
    </div>
  </div>
</Base>
