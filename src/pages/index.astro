---
import Base from '../layouts/Base.astro';
import activities from '../../data/activities.json';

// Group by month
const groups = {};
for (const a of activities) {
  const key = new Date(a.date).toLocaleDateString('en-GB', {
    month: 'long', year: 'numeric', timeZone: a.timezone
  }).toUpperCase();
  if (!groups[key]) groups[key] = [];
  groups[key].push(a);
}

function fmtDist(m) {
  return (m / 1000).toFixed(1) + 'KM';
}

function fmtDate(iso, tz) {
  const today = new Date(new Date().toLocaleDateString('en-CA', { timeZone: tz }));
  const runDay = new Date(new Date(iso).toLocaleDateString('en-CA', { timeZone: tz }));
  const diff = Math.round((today.getTime() - runDay.getTime()) / 86400000);
  if (diff === 0) return 'TODAY';
  if (diff === 1) return 'YESTERDAY';
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', timeZone: tz
  }).toUpperCase();
}

function fmtTime(iso, tz) {
  return new Date(iso).toLocaleTimeString('en-GB', {
    hour: '2-digit', minute: '2-digit', timeZone: tz, hour12: false
  });
}

function monthTotal(acts) {
  return (acts.reduce((s, a) => s + a.distance_m, 0) / 1000).toFixed(0) + 'KM';
}
---

<Base>
  <div class="wrap">
    {Object.entries(groups).map(([month, acts]) => (
      <div>
        <div class="month-header">
          <span>{month.split(' ')[0]}</span>
          <span>TOTAL<br />{monthTotal(acts)}</span>
        </div>
        {acts.map(a => (
          <div class="run-card">
            <a href={`${import.meta.env.BASE_URL}run/${a.id}`}>
              <div class="row-3">
                <span>{fmtDate(a.date, a.timezone)}</span>
                <span>{fmtTime(a.date, a.timezone)}</span>
                <span>{a.temperature}°</span>
              </div>
              <div class="row-2"><span>DISTANCE</span><span>{fmtDist(a.distance_m)}</span></div>
              <div class="row-2"><span>EFFORT</span><span>{a.effort}</span></div>
              <div class="row-2"><span>AVG. HR</span><span>{a.heartrate_avg}BPM</span></div>
            </a>
            {(a.track_lat && a.track_lat.length > 2) && (
              <Fragment>
                <canvas id={`map-${a.id}`} class="card-map"></canvas>
                <script type="application/json" id={`mapdata-${a.id}`} set:html={JSON.stringify({lat: a.track_lat, lng: a.track_lng})}></script>
              </Fragment>
            )}
            <div class="run-link"><a href={`${import.meta.env.BASE_URL}run/${a.id}`}>→</a></div>
          </div>
        ))}
      </div>
    ))}
  </div>
</Base>

<script is:inline>
  document.querySelectorAll('canvas.card-map').forEach(function(canvas) {
    var id = canvas.id.replace('map-', '');
    var dataEl = document.getElementById('mapdata-' + id);
    if (!dataEl) return;
    var data;
    try { data = JSON.parse(dataEl.textContent); } catch(e) { return; }
    var lats = data.lat, lngs = data.lng;
    if (!lats || lats.length < 3) return;

    var dpr = window.devicePixelRatio || 1;
    var w = canvas.parentElement.offsetWidth;
    var h = 120;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);

    var pad = 16;
    var minLat = Math.min.apply(null, lats);
    var maxLat = Math.max.apply(null, lats);
    var minLng = Math.min.apply(null, lngs);
    var maxLng = Math.max.apply(null, lngs);
    var rangeW = maxLng - minLng || 0.001;
    var rangeH = maxLat - minLat || 0.001;
    var scale = Math.min((w - pad * 2) / rangeW, (h - pad * 2) / rangeH);
    var offX = (w - rangeW * scale) / 2;
    var offY = (h - rangeH * scale) / 2;
    var toX = function(lng) { return offX + (lng - minLng) * scale; };
    var toY = function(lat) { return h - offY - (lat - minLat) * scale; };

    ctx.beginPath();
    ctx.moveTo(toX(lngs[0]), toY(lats[0]));
    for (var i = 1; i < lats.length; i++) ctx.lineTo(toX(lngs[i]), toY(lats[i]));
    ctx.strokeStyle = '#1a1814';
    ctx.lineWidth = 1.5;
    ctx.lineJoin = 'round';
    ctx.lineCap = 'round';
    ctx.stroke();

    ctx.beginPath();
    ctx.arc(toX(lngs[0]), toY(lats[0]), 3, 0, Math.PI * 2);
    ctx.fillStyle = '#1a1814';
    ctx.fill();
  });
</script>
