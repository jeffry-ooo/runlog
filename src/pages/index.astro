---
import Base from '../layouts/Base.astro';
import activities from '../lib/activities.js';

function fmtDist(m) {
  return (m / 1000).toFixed(1) + 'KM';
}

function fmtDate(iso, tz) {
  const today = new Date(new Date().toLocaleDateString('en-CA', { timeZone: tz }));
  const runDay = new Date(new Date(iso).toLocaleDateString('en-CA', { timeZone: tz }));
  const diff = Math.round((today.getTime() - runDay.getTime()) / 86400000);
  if (diff === 0) return 'TODAY';
  if (diff === 1) return 'YESTERDAY';
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', timeZone: tz
  }).toUpperCase();
}

function fmtTime(iso, tz) {
  return new Date(iso).toLocaleTimeString('en-GB', {
    hour: '2-digit', minute: '2-digit', timeZone: tz, hour12: false
  });
}
---

<Base>
  <div class="wrap">
    {activities.map(a => (
      <div class="run-card">
        <a href={`${import.meta.env.BASE_URL}run/${a.id}`}>
          <div class="row-3">
            <span>{fmtDate(a.date, a.timezone)}</span>
            <span>{fmtTime(a.date, a.timezone)}</span>
            <span>{a.temperature}°</span>
          </div>
          <div class="row-2"><span>DISTANCE</span><span>{fmtDist(a.distance_m)}</span></div>
          <div class="row-2"><span>EFFORT</span><span>{a.effort}</span></div>
          <div class="row-2"><span>AVG. HR</span><span>{a.heartrate_avg}BPM</span></div>
        </a>
        <div class="run-link"><a href={`${import.meta.env.BASE_URL}run/${a.id}`}>ALL DATA</a></div>
      </div>
    ))}
  </div>
</Base>
